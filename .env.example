# ============================================================================
#  ENVIRONMENT VARIABLES — copy this file to ".env" and fill in real values.
#  NEVER commit the real .env. All secrets are read from these variables only;
#  there are NO hardcoded keys anywhere in the source code.
# ============================================================================

# ---- Supabase (the ONLY backend service) ----------------------------------
# Public values (safe to expose to the browser; injected at build time).
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-SUPABASE-ANON-KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-side mirrors of the public values (used during SSR / server routes).
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR-SUPABASE-ANON-KEY"
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-ONLY secret. Bypasses Row Level Security. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SUPABASE-SERVICE-ROLE-KEY"

# ---- Telegram bot (independent notification module) -----------------------
# From @BotFather. Used server-side only to send event notifications.
TELEGRAM_BOT_TOKEN="123456:ABC-YOUR-BOT-TOKEN"
# The chat/channel/group ID that should receive notifications.
TELEGRAM_CHAT_ID="-1001234567890"

# ---- Deployment target (build-time) ---------------------------------------
# vercel | netlify | node-server (VPS/Docker/Railway/Render) | cloudflare-module
# Vercel reads this from vercel.json, Netlify from netlify.toml.
# For a plain Node/Docker build leave it as node-server (the default).
NITRO_PRESET="node-server"
